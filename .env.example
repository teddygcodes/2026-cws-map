# Copy to .env.local for local dev. NEVER commit real values.
# Generate with: npx auth secret
AUTH_SECRET=

# Google OAuth (Google Cloud Console > APIs & Services > Credentials)
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (passwordless email magic link). Set up at https://resend.com,
# verify your sending domain (SPF/DKIM), then set the API key here.
# The "from" address is configured in auth.js — keep them aligned.
AUTH_RESEND_KEY=

# Vercel-injected when you add the Vercel Postgres integration.
# Locally, paste your Neon/Postgres connection string.
POSTGRES_URL=

# Optional: explicit base URL (Vercel usually infers).
# AUTH_URL=https://your-domain.com
